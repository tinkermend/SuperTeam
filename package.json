{
  "name": "superteam",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:web": "pnpm --filter @superteam/web dev",
    "build:web": "pnpm --filter @superteam/web build",
    "dev:control-plane": "go run ./apps/control-plane/cmd/control-plane",
    "dev:runtime-agent": "go run ./apps/runtime-agent/cmd/runtime-agent --once",
    "generate:control-plane": "cd apps/control-plane && go generate ./internal/api",
    "test": "pnpm test:ts && pnpm test:go",
    "test:ts": "pnpm -r --if-present test",
    "test:go": "go test ./apps/control-plane/... ./apps/runtime-agent/...",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
