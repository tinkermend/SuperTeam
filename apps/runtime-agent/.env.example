# Runtime Agent 环境变量覆盖示例
# 推荐基础配置写在 apps/runtime-agent/config.toml；
# 这些变量用于本机临时覆盖、容器和部署平台注入。
# 优先级：CLI 参数 > RUNTIME_AGENT_* 环境变量 > config.toml > 默认值。

# 节点 ID
RUNTIME_AGENT_NODE_ID=local-dev-node

# Control Plane API 地址
RUNTIME_AGENT_CONTROL_PLANE_URL=http://localhost:8080

# 心跳间隔（秒）
RUNTIME_AGENT_HEARTBEAT_INTERVAL=30

# 最大并发任务数
RUNTIME_AGENT_MAX_CONCURRENT_TASKS=3

# Runtime Agent 本地 HTTP/WS 服务监听地址
RUNTIME_AGENT_HTTP_ADDR=127.0.0.1:7077

# Provider 执行日志和事件落盘目录
RUNTIME_AGENT_RUN_LOG_DIR=.superteam/runtime-runs

# 工作目录基础路径
RUNTIME_AGENT_WORKSPACE_DIR=.superteam/workspaces

# 工作目录清理策略：on_success | on_completion | manual
RUNTIME_AGENT_CLEANUP_POLICY=on_success

# 工作目录最大保留数量
RUNTIME_AGENT_MAX_RETAINED_WORKSPACES=10

# Claude Code Provider
RUNTIME_AGENT_PROVIDER_CLAUDE_CODE_ENABLED=true
RUNTIME_AGENT_PROVIDER_CLAUDE_CODE_BINARY=claude
RUNTIME_AGENT_PROVIDER_CLAUDE_CODE_TIMEOUT=3600

# OpenCode Provider
RUNTIME_AGENT_PROVIDER_OPENCODE_ENABLED=false
RUNTIME_AGENT_PROVIDER_OPENCODE_BINARY=opencode
RUNTIME_AGENT_PROVIDER_OPENCODE_TIMEOUT=3600

# 日志级别：trace | debug | info | warn | error
RUNTIME_AGENT_LOG_LEVEL=info

# 日志格式：json | pretty
RUNTIME_AGENT_LOG_FORMAT=pretty

# 日志输出：stdout | file
RUNTIME_AGENT_LOG_OUTPUT=stdout

# 日志文件路径（当 output = file 时）
RUNTIME_AGENT_LOG_FILE_PATH=.superteam/runtime-agent.log
