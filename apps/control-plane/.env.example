# Control Plane 环境变量配置
# 环境变量优先级高于 config.yaml

# HTTP 服务监听地址
CONTROL_PLANE_ADDR=:8080

# PostgreSQL 数据库连接
DATABASE_URL=postgres://superteam:change-me@127.0.0.1:5432/superteam?sslmode=disable

# Redis 连接
REDIS_URL=redis://:change-me@127.0.0.1:6379/0

# S3 兼容对象存储
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=superteam-artifacts
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true

# 日志级别：debug | info | warn | error
LOG_LEVEL=info
