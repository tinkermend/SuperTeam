# SuperTeam 项目配置模板
# 复制此文件为 .env.local 并填入实际值

# ============================================
# Control Plane (Go 后端)
# ============================================
# HTTP 服务监听地址
CONTROL_PLANE_ADDR=:8080

# PostgreSQL 数据库连接
DATABASE_URL=postgres://superteam:xxxxx@ip:5432/superteam?sslmode=disable

# Redis 连接
REDIS_URL=redis://:xxxx@ip:6379/0

# S3 兼容对象存储（用于工件、日志、报告）
# Volcengine TOS 示例：
# S3_ENDPOINT=https://tos-s3-cn-beijing.volces.com
# S3_REGION=cn-beijing
# S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=superteam-artifacts
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true

# ============================================
# Web Console (Next.js 前端)
# ============================================
# Control Plane API 地址（浏览器访问）
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:8080

# WebSocket 地址（实时事件）
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# 是否启用 Mock 数据（开发调试用）
NEXT_PUBLIC_ENABLE_MOCK=false

# 日志级别：debug | info | warn | error
NEXT_PUBLIC_LOG_LEVEL=info

# ============================================
# Runtime Agent (Rust daemon)
# ============================================
# Runtime Agent 节点 ID（留空则自动生成）
RUNTIME_AGENT_NODE_ID=

# Control Plane API 地址（Runtime Agent 访问）
RUNTIME_AGENT_CONTROL_PLANE_URL=http://localhost:8080

# 心跳间隔（秒）
RUNTIME_AGENT_HEARTBEAT_INTERVAL=30

# 最大并发任务数
RUNTIME_AGENT_MAX_CONCURRENT_TASKS=3

# 工作目录基础路径
RUNTIME_AGENT_WORKSPACE_DIR=/var/superteam/workspaces

# 工作目录清理策略：on_success | on_completion | manual
RUNTIME_AGENT_CLEANUP_POLICY=on_success

# Claude Code Provider 配置
RUNTIME_AGENT_PROVIDER_CLAUDE_CODE_ENABLED=true
RUNTIME_AGENT_PROVIDER_CLAUDE_CODE_BINARY=/usr/local/bin/claude

# OpenCode Provider 配置
RUNTIME_AGENT_PROVIDER_OPENCODE_ENABLED=false
RUNTIME_AGENT_PROVIDER_OPENCODE_BINARY=/usr/local/bin/opencode

# ============================================
# 共享配置
# ============================================
# 环境标识：development | staging | production
SUPERTEAM_ENV=development

# 日志级别（后端服务）
LOG_LEVEL=info
